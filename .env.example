# =============================================================================
# ENV Example — Hermes Agent Configuration
# Copy to ~/.hermes/profiles/bruno/.env and fill in real values
# =============================================================================

# === LLM Providers ===
DEEPSEEK_API_KEY=your_deepseek_api_key_here
OPENROUTER_API_KEY=your_openrouter_api_key_here
GOOGLE_API_KEY=your_google_gemini_api_key_here

# === HuggingFace ===
HF_TOKEN=your_huggingface_token_here

# === NVIDIA ===
NVIDIA_API_KEY=your_nvidia_nim_key_here
NVIDIA_NGC_KEY=your_nvidia_ngc_key_here

# === Others ===
OLLAMA_API_KEY=your_ollama_cloud_key_here
OPENCODE_API_KEY=your_opencode_key_here
QWEN_API_KEY=your_qwen_alibaba_key_here

# === GitHub ===
# One of:
GITHUB_PAT=your_github_classic_pat_here
# Or:
GITHUB_PAT_FINE=your_github_fine_grained_pat_here

# === Docker ===
DOCKER_HUB_USER=your_dockerhub_username
DOCKER_HUB_PAT=your_dockerhub_pat_here
